# Track Leader Production Environment
# Copy this to .env.production and fill in your values

# =============================================================================
# REQUIRED - Supabase Database
# =============================================================================
# Get this from: Supabase Dashboard > Settings > Database > Connection string
# Use the "URI" format, and select "Mode: Session" for connection pooling
# Example: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# =============================================================================
# REQUIRED - Authentication
# =============================================================================
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes)
PASETO_KEY=

# =============================================================================
# REQUIRED - Domain & CORS
# =============================================================================
# Your domain name (used by Caddy for automatic HTTPS)
DOMAIN=tracks.example.com

# CORS allowed origins (comma-separated for multiple domains)
# Use "*" to allow all origins (not recommended for production)
CORS_ORIGINS=https://tracks.example.com

# =============================================================================
# REQUIRED - Object Storage (S3)
# =============================================================================
# Set to "s3" to use S3 storage (default: local filesystem)
OBJECT_STORE_BACKEND=s3

# S3 bucket name
AWS_S3_BUCKET=tracks.rs-663959447334-us-west-1-an

# Prefix within the bucket for all stored objects
AWS_S3_PREFIX=uploads

# AWS region
AWS_REGION=us-west-1

# AWS credentials (or use IAM roles / instance profiles)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# OPTIONAL - Defaults shown
# =============================================================================

# Logging level: trace, debug, info, warn, error
RUST_LOG=info

# Connection pool settings (keep low for Supabase free tier)
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2

# Public API URL (usually https://your-domain.com)
# Only needed if frontend needs to know the public URL
# NEXT_PUBLIC_API_URL=https://tracks.example.com
